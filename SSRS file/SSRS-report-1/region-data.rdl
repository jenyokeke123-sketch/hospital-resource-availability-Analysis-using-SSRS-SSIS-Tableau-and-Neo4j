<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=DESKTOP-P6BIPUG\SQLEXPRESS;Initial Catalog=Bed_capacity</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>2777d5ba-7785-4c4f-9876-0a7965a9bf6e</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT 
    r.NYForwardRegion AS Region,
    SUM(f.Total_Staffed_Acute_Care_Beds) AS TotalAcuteBeds,
    SUM(f.Total_Staffed_Acute_Care_Beds_Available) AS AvailableAcuteBeds,
    SUM(f.Total_Staffed_ICU_Beds) AS TotalICUBeds,
    SUM(f.Total_Staffed_ICU_Beds_Currently_Available) AS AvailableICUBeds
FROM Fact_FacilityCapacity f
LEFT JOIN Region_Dim r ON f.RegionID = r.RegionID
GROUP BY r.NYForwardRegion
ORDER BY r.NYForwardRegion;</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Region">
          <DataField>Region</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TotalAcuteBeds">
          <DataField>TotalAcuteBeds</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="AvailableAcuteBeds">
          <DataField>AvailableAcuteBeds</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TotalICUBeds">
          <DataField>TotalICUBeds</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="AvailableICUBeds">
          <DataField>AvailableICUBeds</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
