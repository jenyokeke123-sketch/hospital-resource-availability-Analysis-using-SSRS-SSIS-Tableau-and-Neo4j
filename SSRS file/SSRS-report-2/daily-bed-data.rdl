<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=DESKTOP-P6BIPUG\SQLEXPRESS;Initial Catalog=Bed_capacity</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>225a2189-31cf-49cb-a773-800e0fb147ae</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT        d.AsOfDate, SUM(f.Total_Staffed_Acute_Care_Beds_Occupied) AS AcuteOccupied, SUM(f.Total_Staffed_ICU_Beds_Currently_Occupied) AS ICUOccupied, 
                         SUM(f.Total_Staffed_Acute_Care_Beds_Occupied + f.Total_Staffed_ICU_Beds_Currently_Occupied) AS TotalOccupied
FROM            Fact_FacilityCapacity AS f INNER JOIN
                         Data_Dim AS d ON f.DateID = d.DateID
GROUP BY d.AsOfDate
ORDER BY d.AsOfDate</CommandText>
      </Query>
      <Fields>
        <Field Name="AsOfDate">
          <DataField>AsOfDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="AcuteOccupied">
          <DataField>AcuteOccupied</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ICUOccupied">
          <DataField>ICUOccupied</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TotalOccupied">
          <DataField>TotalOccupied</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
